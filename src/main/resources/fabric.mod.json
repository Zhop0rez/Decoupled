{
	"schemaVersion": 1,
	"id": "perfectlan",
	"version": "${version}",
	"name": "Decoupled",
	"description": "True asynchronous singleplayer. Runs the integrated server in a separate background process for extreme performance and smooth 1% lows.",
	"authors": [
		"Zhoporez"
	],
	"contact": {},
	"license": "CC0-1.0",
	"icon": "assets/perfectlan/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.perfectlan.PerfectLAN"
		],
		"client": [
			"com.perfectlan.client.PerfectLANClient"
		]
	},
	"mixins": [
		"perfectlan.mixins.json",
		{
			"config": "perfectlan.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}